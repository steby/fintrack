# Copy to .env and fill in. See spec.md Phase 0 step 3 for the Neon branch setup
# (Production is the default branch — never used for dev/CI; dev and ci are child branches).

# Database (Neon Postgres)
DATABASE_URL=

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# App
APP_URL=http://localhost:3000

# Seed (used only by `npm run db:seed`, never read at runtime). Also read directly by
# e2e/auth.spec.ts and e2e/invite.spec.ts to log in as the seeded owner — the E2E suite
# needs these set to whatever npm run db:seed actually created, same as CI does via its
# own SEED_OWNER_EMAIL/PASSWORD secrets against the `ci` branch.
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=

# Cron (secures /api/cron/* endpoints — Phase 6)
CRON_SECRET=

# Optional — keys-optional integrations (app runs identically without these)
RESEND_API_KEY=
SENTRY_DSN=

# Feature flags — config kind (env var; changing requires a restart/redeploy)
FEATURE_CATEGORY_BUDGETS=true
FEATURE_SAVINGS_GOALS=true
FEATURE_NET_WORTH=true
FEATURE_ENTRY_ATTRIBUTION=true
FEATURE_PWA=true

# Feature flags — kill-switch kind (these seed the household_settings DB defaults only;
# toggle at runtime via Settings once seeded, not by editing this file)
FEATURE_AUTO_GENERATE_DEFAULT=true
FEATURE_CSV_IMPORT_DEFAULT=false
FEATURE_EMAIL_REMINDERS_DEFAULT=false
FEATURE_MONTHLY_RECAP_DEFAULT=false
